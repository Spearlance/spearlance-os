# ============================================================
# SpearlanceOS Environment Configuration
# ============================================================
# TWO ENVIRONMENTS:
#   Production  → Vercel env vars (set in Vercel dashboard, scope = Production)
#                 Branch: main only. Deploys to os.spearlance.com.
#                 Supabase project: chikljxwgiskyjsnjelf
#
#   Development → .env.local (gitignored, your local machine)
#                 Local: npm run dev → reads .env then .env.local (override).
#                 Vercel preview branches: scope = Preview env vars.
#                 Persistent dev branch on prod project: zlljsdaxsggkasvympku
#                 (forked schema, isolated DB — see Supabase Branching)
#
# To set up local dev:
#   1. Copy this file to .env.local
#   2. Fill in dev branch Supabase credentials
#   3. Use Stripe TEST keys (sk_test_*, pk_test_*) — never live keys
#   4. npm run dev — automatically reads .env.local
#
# NEVER commit secrets. .env, .env.local, .env.production are all gitignored.
# ============================================================

# Supabase Configuration
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PROJECT_ID=

# Cal.com Configuration
VITE_CAL_OAUTH_CLIENT_ID=
VITE_CAL_ORG_ID=
VITE_CAL_API_URL=https://api.cal.com/v2
VITE_CAL_REFRESH_URL=

# Stripe Configuration
VITE_STRIPE_STARTER_MONTHLY_PRICE_ID=
VITE_STRIPE_STARTER_ANNUAL_PRICE_ID=
VITE_STRIPE_UNLIMITED_MONTHLY_PRICE_ID=
VITE_STRIPE_UNLIMITED_ANNUAL_PRICE_ID=
VITE_STRIPE_WEBSITE_ADDON_PRICE_ID=

# Stripe Edge Function Secrets (set in Supabase Dashboard → Edge Functions → Secrets)
STRIPE_UNLIMITED_PRODUCT_ID=
STRIPE_STARTER_PRICE_ID=

# AI Services (set in Supabase Dashboard → Edge Functions → Secrets)
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Google PageSpeed Insights (optional — recommended for rate limits on Lighthouse audits)
GOOGLE_PSI_API_KEY=

# DataforSEO (SERP + keyword data for optimization engine)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# App Configuration
VITE_APP_URL=https://os.spearlance.com

# Playwright E2E Tests (test account — never use real client creds)
PLAYWRIGHT_TEST_EMAIL=
PLAYWRIGHT_TEST_PASSWORD=
PLAYWRIGHT_BASE_URL=http://localhost:8080
