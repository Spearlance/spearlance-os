# ============================================================
# SpearlanceOS Environment Variables
# ============================================================
# Copy this file to .env or .env.local and fill in your values.
# NEVER commit .env or .env.local to git.
# ============================================================

# --- Supabase (Required) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- App ---
VITE_APP_URL=http://localhost:5173

# --- Cal.com Integration (Optional — meetings feature) ---
VITE_CAL_OAUTH_CLIENT_ID=
VITE_CAL_ORG_ID=
VITE_CAL_API_URL=https://api.cal.com/v2
VITE_CAL_REFRESH_URL=

# --- Stripe Billing (Required for billing features) ---
VITE_STRIPE_STARTER_MONTHLY_PRICE_ID=
VITE_STRIPE_STARTER_ANNUAL_PRICE_ID=
VITE_STRIPE_UNLIMITED_MONTHLY_PRICE_ID=
VITE_STRIPE_UNLIMITED_ANNUAL_PRICE_ID=

# ============================================================
# Supabase Edge Function Secrets (set via supabase secrets set)
# ============================================================
# SUPABASE_URL              — auto-provided by Supabase
# SUPABASE_ANON_KEY         — auto-provided by Supabase
# SUPABASE_SERVICE_ROLE_KEY — auto-provided by Supabase
#
# OPENROUTER_API_KEY        — AI content generation (chat, blogs, social)
# OPENAI_API_KEY            — Asset analysis, embeddings
# STRIPE_SECRET_KEY         — Stripe server-side API
# STRIPE_WEBHOOK_SECRET     — Stripe webhook verification
# STRIPE_STARTER_PRICE_ID   — Stripe price IDs
# STRIPE_UNLIMITED_PRODUCT_ID
# STRIPE_WEBSITE_PRICE_ID
# STRIPE_WEBSITE_PRODUCT_ID
# RESEND_API_KEY            — Transactional emails
# DUDA_API_KEY              — Website builder integration
# DUDA_API_USER             — Duda API username
# LATE_API_KEY              — Social media scheduling (Latenode)
# PEXELS_API_KEY            — Stock image search
# FRONT_API_TOKEN           — Front.com communication logs
# FRONT_WEBHOOK_SECRET      — Front.com webhook verification
# CAL_PLATFORM_CLIENT_ID    — Cal.com platform API
# CAL_PLATFORM_CLIENT_SECRET
# CAL_WEBHOOK_SECRET        — Cal.com webhook verification
# IP_HASH_SALT              — Analytics IP anonymization
# APP_URL                   — Public app URL for email links
